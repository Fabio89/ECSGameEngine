{
  "version": 6,

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg/installed",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "warnings": {
        "dev": false
      }
    },

    {
      "name": "debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/Build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "debug-asan",
      "inherits": "debug",
      "binaryDir": "${sourceDir}/Build/debug-asan",
      "cacheVariables": {
        "ENABLE_ASAN": "ON"
      }
    },

    {
      "name": "development",
      "inherits": "base",
      "binaryDir": "${sourceDir}/Build/development",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Development"
      }
    },

    {
      "name": "development-asan",
      "inherits": "development",
      "binaryDir": "${sourceDir}/Build/development-asan",
      "cacheVariables": {
        "ENABLE_ASAN": "ON"
      }
    },

    {
      "name": "release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/Build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "release-asan",
      "inherits": "release",
      "binaryDir": "${sourceDir}/Build/release-asan",
      "cacheVariables": {
        "ENABLE_ASAN": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ]
}